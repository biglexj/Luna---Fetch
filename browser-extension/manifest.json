{
  "manifest_version": 3,
  "name": "Luna Fetch",
  "version": "1.0.4",
  "description": "Descarga videos y audio desde YouTube directamente con Luna Fetch.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://music.youtube.com/*",
    "http://127.0.0.1:51234/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
